#!/usr/bin/env bash
#
# Grimoire — personal machine configuration manager.
# Bash ensures nix and uv are available; Python CLI handles everything else.

set -euo pipefail

grimoire_root="$(cd "$(dirname "$0")" && pwd)"

# 1. Make nix and any nix-darwin-installed tools available on PATH.
#    Harmless if the directories don't exist yet — PATH entries to missing
#    directories are skipped.
nix_profile=/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
[ -f "$nix_profile" ] && . "$nix_profile"
export PATH="/run/current-system/sw/bin:$PATH"

# 2. Install Nix if missing
if ! command -v nix &>/dev/null; then
    echo "  nix not found."
    printf "  Install nix (Determinate Systems)? [y/N] "
    read -r answer
    case "$answer" in
        [yY]*)
            curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | sh -s -- install
            . "$nix_profile"
            ;;
        *)
            echo "  nix is required. Aborting." >&2
            exit 1
            ;;
    esac
fi

# 3. Create ~/.grimoire symlink (ensures Python CLI can always rely on it)
link="$HOME/.grimoire"
if [ "$grimoire_root" != "$link" ]; then
    if [ -L "$link" ] && [ "$(readlink "$link")" = "$grimoire_root" ]; then
        : # already correct
    elif [ -L "$link" ]; then
        rm "$link"
        ln -s "$grimoire_root" "$link"
        echo "  updated $link -> $grimoire_root"
    elif [ ! -e "$link" ]; then
        ln -s "$grimoire_root" "$link"
        echo "  created $link -> $grimoire_root"
    else
        echo "  WARNING: $link exists and is not a symlink — skipping" >&2
    fi
fi

# 4. Hand off to Python. If uv isn't on PATH yet (truly first run),
#    make it temporarily available via `nix shell` for this invocation.
#    `grimoire bootstrap` will then install it system-wide via darwin-rebuild,
#    so subsequent invocations find it directly without the nix-shell detour.
if command -v uv &>/dev/null; then
    exec env PYTHONPATH="$grimoire_root" \
        uv run --project "$grimoire_root" python -m arcana.cli "$@"
else
    exec nix shell nixpkgs#uv --command env PYTHONPATH="$grimoire_root" \
        uv run --project "$grimoire_root" python -m arcana.cli "$@"
fi
