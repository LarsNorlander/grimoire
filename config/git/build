#!/usr/bin/env python3
"""Copies gitconfig to tome/git/."""

import shutil
import sys
from pathlib import Path

grimoire_root = Path(sys.argv[2])
src = grimoire_root / "config" / "git" / "gitconfig"
dst = grimoire_root / "tome" / "git"
dst.mkdir(parents=True, exist_ok=True)
shutil.copy2(src, dst / "gitconfig")
print("  built tome/git/gitconfig")
