#!/usr/bin/env python3
"""Copies starship.toml to tome/starship/."""

import shutil
import sys
from pathlib import Path

grimoire_root = Path(sys.argv[2])
src = grimoire_root / "config" / "starship" / "starship.toml"
dst = grimoire_root / "tome" / "starship"
dst.mkdir(parents=True, exist_ok=True)
shutil.copy2(src, dst / "starship.toml")
print("  built tome/starship/starship.toml")
