#!/usr/bin/env python3
"""
Builds aerospace.toml from base config + optional work overlay.

Usage: build <profile> <grimoire_root>
  profile: 'work' or 'personal'
"""

import sys
from pathlib import Path

import tomlkit
from tomlkit.items import Table, AoT, Comment, Whitespace


def merge_into_table(base_table, overlay_table):
    """Merge overlay keys into a tomlkit table, inserting before trailing trivia."""
    for key, value in overlay_table.items():
        if key in base_table:
            base_val = base_table[key]
            if isinstance(base_val, dict) and isinstance(value, dict):
                merge_into_table(base_val, value)
            elif isinstance(base_val, list) and isinstance(value, list):
                base_val.extend(value)
            else:
                base_table[key] = value
        else:
            base_table.add(key, value)


def merge_service_d(base_binding, work_d_entries):
    """Insert work 'd' entries before the trailing exit commands."""
    current = base_binding["d"]
    # Exit commands are the last 2: 'workspace ...' and 'mode main'
    body = list(current[:-2])
    tail = list(current[-2:])
    merged = tomlkit.array(body + list(work_d_entries) + tail)
    merged.multiline(True)
    base_binding["d"] = merged


def main():
    profile = sys.argv[1]
    grimoire_root = Path(sys.argv[2])
    config_dir = grimoire_root / "config" / "aerospace"
    tome_dir = grimoire_root / "tome"

    with open(config_dir / "base.toml") as f:
        doc = tomlkit.load(f)

    if profile == "work":
        with open(config_dir / "work.toml") as f:
            overlay = tomlkit.load(f)

        # Extract and remove service 'd' before general merge (needs special handling)
        work_d_entries = None
        if "mode" in overlay:
            service_binding = overlay.get("mode", {}).get("service", {}).get("binding", {})
            if "d" in service_binding:
                work_d_entries = list(service_binding["d"])
                del service_binding["d"]

        merge_into_table(doc, overlay)

        if work_d_entries:
            merge_service_d(doc["mode"]["service"]["binding"], work_d_entries)

    tome_dir.mkdir(exist_ok=True)
    with open(tome_dir / "aerospace.toml", "w") as f:
        tomlkit.dump(doc, f)

    print(f"  built tome/aerospace.toml ({profile})")


if __name__ == "__main__":
    main()
