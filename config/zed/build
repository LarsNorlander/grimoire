#!/usr/bin/env python3
"""Copies settings.json to tome/zed/."""

import shutil
import sys
from pathlib import Path

grimoire_root = Path(sys.argv[2])
src = grimoire_root / "config" / "zed" / "settings.json"
dst = grimoire_root / "tome" / "zed"
dst.mkdir(parents=True, exist_ok=True)
shutil.copy2(src, dst / "settings.json")
print("  built tome/zed/settings.json")
