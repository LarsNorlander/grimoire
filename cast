#!/usr/bin/env bash
#
# Deploys grimoire onto the current machine.
# Bash handles first-run bootstrap; Python CLI handles everything else.

set -euo pipefail

grimoire_root="$(cd "$(dirname "$0")" && pwd)"

# 1. Source Nix daemon profile
nix_profile=/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
[ -f "$nix_profile" ] && . "$nix_profile"

# 2. Install Nix if missing
if ! command -v nix &>/dev/null; then
    echo "  nix not found."
    printf "  Install nix (Determinate Systems)? [y/N] "
    read -r answer
    case "$answer" in
        [yY]*)
            curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | sh -s -- install
            . "$nix_profile"
            ;;
        *)
            echo "  nix is required. Aborting." >&2
            exit 1
            ;;
    esac
fi

# 3. Create ~/.grimoire symlink (ensures Python CLI can always rely on it)
link="$HOME/.grimoire"
if [ "$grimoire_root" != "$link" ]; then
    if [ -L "$link" ] && [ "$(readlink "$link")" = "$grimoire_root" ]; then
        : # already correct
    elif [ -L "$link" ]; then
        rm "$link"
        ln -s "$grimoire_root" "$link"
        echo "  updated $link -> $grimoire_root"
    elif [ ! -e "$link" ]; then
        ln -s "$grimoire_root" "$link"
        echo "  created $link -> $grimoire_root"
    else
        echo "  WARNING: $link exists and is not a symlink — skipping" >&2
    fi
fi

# 4. First-run bootstrap: apply runes if uv not yet installed
if ! command -v uv &>/dev/null; then
    profile_file="$HOME/.grimoire-profile"
    if [ ! -f "$profile_file" ]; then
        printf "Is this a work machine? [y/N] "
        read -r answer
        case "$answer" in [yY]*) echo "work" ;; *) echo "personal" ;; esac > "$profile_file"
    fi
    flake="$grimoire_root/runes#$(cat "$profile_file")"
    if command -v darwin-rebuild &>/dev/null; then
        sudo darwin-rebuild switch --flake "$flake"
    else
        sudo nix run nix-darwin -- switch --flake "$flake"
    fi
    export PATH="/run/current-system/sw/bin:$PATH"
fi

# 5. Hand off to Python
exec env PYTHONPATH="$grimoire_root" uv run --project "$grimoire_root" python -m arcana.cli "$@"
