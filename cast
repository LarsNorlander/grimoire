#!/usr/bin/env bash
#
# Deploys grimoire onto the current machine.
# Ensures prerequisites, resolves profile, links ~/.grimoire, and builds rites.
#
# Usage:
#   ./cast              # first run prompts for profile
#   ./cast --recast     # re-prompt for profile
#   ./cast --force      # overwrite externally modified tome files
#   ./cast --accept git  # accept external changes back into rite sources

set -euo pipefail

grimoire_root="$(cd "$(dirname "$0")" && pwd)"
profile_file="$HOME/.grimoire-profile"

# --- Helpers ---

confirm() {
    local prompt="$1"
    printf "%s [y/N] " "$prompt"
    read -r answer
    case "$answer" in
        [yY]*) return 0 ;;
        *) return 1 ;;
    esac
}

run_arcana() {
    (cd "$grimoire_root" && PYTHONPATH="$grimoire_root" uv run "$@")
}

# --- Prerequisites ---

ensure_prerequisites() {
    local venv_dir="$grimoire_root/.venv"
    local lock_file="$grimoire_root/uv.lock"

    # Fast path: everything already set up and lock hasn't changed
    if command -v brew &>/dev/null && command -v uv &>/dev/null \
        && [ -d "$venv_dir" ] && [ -f "$lock_file" ] \
        && [ ! "$lock_file" -nt "$venv_dir" ]; then
        return
    fi

    echo "Checking prerequisites..."

    if ! command -v brew &>/dev/null; then
        echo "  Homebrew not found."
        if confirm "  Install Homebrew?"; then
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        else
            echo "  Homebrew is required. Aborting." >&2
            exit 1
        fi
    else
        echo "  Homebrew: ok"
    fi

    if ! command -v uv &>/dev/null; then
        echo "  uv not found."
        if confirm "  Install uv via brew?"; then
            brew install uv
        else
            echo "  uv is required. Aborting." >&2
            exit 1
        fi
    else
        echo "  uv: ok"
    fi

    echo "  Syncing dependencies..."
    (cd "$grimoire_root" && uv sync --quiet)
    touch "$venv_dir"
    echo "  Dependencies: ok"

    echo ""
}

# --- Profile ---

read_or_prompt_profile() {
    if [ -f "$profile_file" ] && [ "$recast" = false ]; then
        profile="$(cat "$profile_file")"
        echo "Profile: $profile (from $profile_file)"
    else
        printf "Is this a work machine? [y/N] "
        read -r answer
        case "$answer" in
            [yY]*) profile="work" ;;
            *) profile="personal" ;;
        esac
        echo "$profile" > "$profile_file"
        echo "Profile: $profile (saved to $profile_file)"
    fi

    echo ""
}

# --- Grimoire root ---

link_grimoire_root() {
    if [ "$grimoire_root" = "$HOME/.grimoire" ]; then
        return
    fi

    local link="$HOME/.grimoire"
    if [ -L "$link" ] && [ "$(readlink "$link")" = "$grimoire_root" ]; then
        return
    fi

    if [ -L "$link" ]; then
        rm "$link"
        echo "  updated $link -> $grimoire_root"
    elif [ -e "$link" ]; then
        echo "  ERROR: $link already exists and is not a symlink — skipping" >&2
        return 1
    else
        echo "  created $link -> $grimoire_root"
    fi
    ln -s "$grimoire_root" "$link"

    echo ""
}

# --- Build ---

build_rites() {
    echo "Building rites..."

    force_flag=""
    if [ "$force" = true ]; then force_flag="--force"; fi

    for build_script in "$grimoire_root"/rites/*/rite; do
        [ -x "$build_script" ] || continue
        run_arcana "$build_script" "$profile" "$grimoire_root" $force_flag
    done

    echo ""
}

# --- Main ---

recast=false
force=false
accept_targets=()
parsing_accept=false
for arg in "$@"; do
    if [ "$parsing_accept" = true ]; then
        accept_targets+=("$arg")
        continue
    fi
    case "$arg" in
        --recast) recast=true ;;
        --force) force=true ;;
        --accept) parsing_accept=true ;;
    esac
done

# Accept mode: run targeted rite scripts with --accept, then exit
if [ "${#accept_targets[@]}" -gt 0 ]; then
    ensure_prerequisites
    echo "Accepting external changes..."
    for target in "${accept_targets[@]}"; do
        rite_script="$grimoire_root/rites/$target/rite"
        if [ ! -x "$rite_script" ]; then
            echo "  ERROR: no rite found for '$target'" >&2
            exit 1
        fi
        run_arcana "$rite_script" "" "$grimoire_root" --accept
    done
    echo ""
    echo "Done."
    exit 0
fi

echo "Casting grimoire from $grimoire_root"
echo ""

ensure_prerequisites
read_or_prompt_profile
link_grimoire_root
build_rites

echo "Done."
