#!/usr/bin/env python3
"""Builds aerospace.toml from base config + optional work overlay."""

import tomlkit

from arcana.tome import RiteContext


def merge_into_table(base_table, overlay_table):
    """Merge overlay keys into a tomlkit table."""
    for key, value in overlay_table.items():
        if key in base_table:
            base_val = base_table[key]
            if isinstance(base_val, dict) and isinstance(value, dict):
                merge_into_table(base_val, value)
            elif isinstance(base_val, list) and isinstance(value, list):
                base_val.extend(value)
            else:
                base_table[key] = value
        else:
            base_table.add(key, value)


def merge_service_d(base_binding, work_d_entries):
    """Insert work 'd' entries before the trailing exit commands."""
    current = base_binding["d"]
    body = list(current[:-2])
    tail = list(current[-2:])
    merged = tomlkit.array(body + list(work_d_entries) + tail)
    merged.multiline(True)
    base_binding["d"] = merged


def build_aerospace(*, profile, rite_dir, **_):
    with open(rite_dir / "base.toml") as f:
        doc = tomlkit.load(f)

    if profile == "work":
        with open(rite_dir / "work.toml") as f:
            overlay = tomlkit.load(f)

        work_d_entries = None
        if "mode" in overlay:
            service_binding = overlay.get("mode", {}).get("service", {}).get("binding", {})
            if "d" in service_binding:
                work_d_entries = list(service_binding["d"])
                del service_binding["d"]

        merge_into_table(doc, overlay)

        if work_d_entries:
            merge_service_d(doc["mode"]["service"]["binding"], work_d_entries)

    return tomlkit.dumps(doc)


ctx = RiteContext.from_args()
ctx.write("aerospace.toml", build_aerospace)
ctx.link("aerospace.toml", "~/.aerospace.toml")
